# Visioryx - Docker defaults (used when .env not present)
# Override via docker-compose environment for production

APP_NAME=Visioryx
DEBUG=false
SECRET_KEY=change-this-in-production-use-openssl-rand-hex-32
# Comma-separated; add https://your-dashboard when deploying
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
FACE_SIMILARITY_THRESHOLD=0.52
