# Visioryx - Environment Configuration
# Copy to .env and update values

# Application
APP_NAME=Visioryx
DEBUG=false

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/visioryx
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/visioryx

# Security - Generate with: openssl rand -hex 32
SECRET_KEY=change-this-in-production-use-openssl-rand-hex-32

# Face Recognition
FACE_SIMILARITY_THRESHOLD=0.6

# GPU (optional)
# CUDA_VISIBLE_DEVICES=0
