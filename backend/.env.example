# Visioryx - Environment Configuration
# Copy to .env and update values

# Application
APP_NAME=Visioryx
DEBUG=false

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/visioryx
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/visioryx

# Security - Generate with: openssl rand -hex 32
SECRET_KEY=change-this-in-production-use-openssl-rand-hex-32
# Allow POST /api/v1/auth/register (self-service accounts). Set false if only admins provision users.
# ALLOW_PUBLIC_REGISTRATION=true
# Face enrollment QR / link JWT lifetime (hours)
# ENROLLMENT_TOKEN_EXPIRE_HOURS=48

# CORS — comma-separated browser origins allowed to call the API (add your production dashboard URL)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Face Recognition (cosine similarity; lower = more matches, higher = stricter)
# Cosine similarity: primary match (0.40–0.50 typical). Lower = more matches, more false accepts.
FACE_SIMILARITY_THRESHOLD=0.45
# Fallback when live view differs from enrollment (profile/side vs frontal photo)
# Relaxed cosine (profile / CCTV vs frontal enrollment); lower = more IDs, more false accepts
FACE_SIMILARITY_THRESHOLD_RELAXED=0.30
# Third pass (sharp profile / far / heavy compression). Set >= RELAXED to disable (e.g. 0.99).
FACE_SIMILARITY_THRESHOLD_WIDE=0.27
# InsightFace det_score floor for live (default ~0.28). Raise if you get false face boxes; lower if distant faces vanish.
# FACE_DETECTION_CONFIDENCE=0.28
# Face detector sensitivity in FaceAnalysis.prepare (default ~0.38). Lower = more side-angle / small faces.
# INSIGHTFACE_DET_THRESH=0.38
# auto = Haar on macOS live stream (stable), InsightFace on Linux; insightface = full AI live (may SIGSEGV on Mac)
# FACE_DETECTION_BACKEND=auto
# If live crashes, you can force Haar-only (no name matching): STREAM_FORCE_HAAR_LIVE=true

# Live MJPEG: JPEG quality (default ~88). Decode size (FFmpeg path) drives face detail — higher = sharper, more CPU.
# STREAM_MAX_WIDTH=1280
# STREAM_JPEG_QUALITY=88
# FFmpeg MJPEG: full InsightFace overlay runs every N frames (higher = smoother, less frequent name updates)
# STREAM_ANNOTATE_EVERY_N_FRAMES=10
# STREAM_UNKNOWN_SNAPSHOT_MIN_INTERVAL_SEC=1.5
# STREAM_SKIP_HOG_MIN_FACE_COUNT=4

# Live streaming (RTSP → MJPEG, FFmpeg path)
# RTSP_CAPTURE_BACKEND=ffmpeg   # ffmpeg (default, stable on macOS) or opencv (may SIGSEGV)
# FFMPEG_PATH=ffmpeg
# STREAM_DECODE_WIDTH=1280
# STREAM_DECODE_HEIGHT=720
# Live face boxes (Haar on macOS when FACE_DETECTION_BACKEND=auto). Default is true; set false only if unstable.
# STREAM_ENABLE_AI_OVERLAY=true
# Full-body person boxes (OpenCV HOG). Default OFF on macOS (can crash with SIGFPE); default ON on Linux. Off when STREAM_ENABLE_YOLO_OVERLAY=true.
# STREAM_ENABLE_HOG_PERSONS=false
# STREAM_ENABLE_YOLO_OVERLAY= # unset: false on macOS. true loads Ultralytics/torch (often SIGSEGV on Mac dev)
# STREAM_FFMPEG_LOW_LATENCY=false # true = nobuffer+low_delay (H.264); false = better HEVC / Dahua-style streams

# GPU (optional)
# CUDA_VISIBLE_DEVICES=0
# INSIGHTFACE_CTX_ID=-1   # -1 CPU (recommended macOS), 0 = first GPU
# INSIGHTFACE_DET_THRESH=0.45   # lower = detect more faces (enrollment / dim photos); default 0.45
