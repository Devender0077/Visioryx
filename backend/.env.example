# Visioryx - Environment Configuration
# Copy to .env and update values

# Application
APP_NAME=Visioryx
DEBUG=false

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/visioryx
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/visioryx

# Security - Generate with: openssl rand -hex 32
SECRET_KEY=change-this-in-production-use-openssl-rand-hex-32

# Face Recognition
FACE_SIMILARITY_THRESHOLD=0.6
# auto = Haar on macOS live stream (stable), InsightFace on Linux; insightface = full AI live (may SIGSEGV on Mac)
# FACE_DETECTION_BACKEND=auto

# Live streaming (RTSP → MJPEG)
# RTSP_CAPTURE_BACKEND=ffmpeg   # ffmpeg (default, stable on macOS) or opencv (may SIGSEGV)
# FFMPEG_PATH=ffmpeg
# STREAM_DECODE_WIDTH=960
# STREAM_DECODE_HEIGHT=540
# STREAM_ENABLE_AI_OVERLAY=   # unset: false on macOS (stable), true on Linux. true = face boxes on live (risky on Mac)
# STREAM_ENABLE_YOLO_OVERLAY= # unset: false on macOS. true loads Ultralytics/torch (often SIGSEGV on Mac dev)
# STREAM_FFMPEG_LOW_LATENCY=false # true = nobuffer+low_delay (H.264); false = better HEVC / Dahua-style streams

# GPU (optional)
# CUDA_VISIBLE_DEVICES=0
# INSIGHTFACE_CTX_ID=-1   # -1 CPU (recommended macOS), 0 = first GPU
