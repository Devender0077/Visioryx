# Backend API (required on a physical device — use your computer's LAN IP, not localhost)
# Example: EXPO_PUBLIC_API_URL=http://192.168.1.10:8000
EXPO_PUBLIC_API_URL=http://localhost:8000

# Optional: Next.js dashboard origin for enrollment links (defaults to localhost:3000)
# EXPO_PUBLIC_DASHBOARD_URL=http://192.168.1.10:3000

# This app targets Expo SDK 54 so it opens in the standard App Store "Expo Go" app.
# (SDK 55+ may show "requires a newer Expo Go" until the store app catches up.)
