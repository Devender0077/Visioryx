# Backend API — REQUIRED on a real phone: use your computer's LAN IP (same Wi‑Fi), NOT localhost.
# Find IP: macOS → System Settings → Network, or run: ipconfig getifaddr en0
# Example (replace with your IP):
EXPO_PUBLIC_API_URL=http://192.168.1.11:8000
# Optional: WebSocket URL for live sync (defaults to same host as API with path /ws)
# EXPO_PUBLIC_WS_URL=ws://192.168.1.11:8000/ws
#
# localhost only works on iOS Simulator / web; a phone's "localhost" is the phone itself.
# After changing this file: stop Metro and run  npm run start:clear

# Optional: Next.js dashboard origin for enrollment links (defaults to localhost:3000)
# EXPO_PUBLIC_DASHBOARD_URL=http://192.168.1.10:3000

# This app targets Expo SDK 54 so it opens in the standard App Store "Expo Go" app.
# (SDK 55+ may show "requires a newer Expo Go" until the store app catches up.)
