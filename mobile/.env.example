# Metro uses :8081 (QR); API uses :8000. Set only EXPO_PUBLIC_API_URL — WebSocket follows via lib/wsUrl.ts unless you set EXPO_PUBLIC_WS_URL.
#
# Backend API — REQUIRED on a real phone: LAN IP (same Wi‑Fi), NOT localhost. ipconfig getifaddr en0
EXPO_PUBLIC_API_URL=http://192.168.1.11:8000
# Optional override (defaults to ws://<same host as API>/ws)
# EXPO_PUBLIC_WS_URL=wss://api.example.com/ws
#
# localhost only works on iOS Simulator / web; a phone's "localhost" is the phone itself.
# After changing EXPO_PUBLIC_*: stop Metro completely, then:
#   npm run start:clear
# (Env is baked into the JS bundle; a running Metro may keep old values.)
#
# Sign-in needs an AuthUser (e.g. seed admin: admin@visioryx.dev / admin123).
# Backend must listen on all interfaces: uvicorn … --host 0.0.0.0 --port 8000
#
# iOS Simulator: use LAN-free bundler (avoids exp://192.168… timeouts):
#   npm run start:sim
#
# Scripts default to Expo Go (`--go`). Custom native code: npx expo install expo-dev-client,
# add the plugin in app.json, then npm run ios:run and start without --go.
#
# "Problem running the requested app" in Expo Go: update Expo Go from the store; try npm run start:tunnel; same Wi‑Fi as the Mac.
# Entry is package.json "main": "expo-router/entry" (do not restore a custom index.js unless Expo docs require it).

# Optional: Next.js dashboard origin for enrollment links (defaults to localhost:3000)
# EXPO_PUBLIC_DASHBOARD_URL=http://192.168.1.10:3000

# This app targets Expo SDK 54 — same line as App Store "Expo Go" (npm run shows SDK in Metro banner).
